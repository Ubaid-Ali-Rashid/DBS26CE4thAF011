@model HotelManagementSystem.Models.Domain.Payment
@{
    ViewData["Title"] = "Payment Details";
}

<h2>Payment Details</h2>
<dl class="row">
    <dt class="col-sm-3">Payment ID</dt>
    <dd class="col-sm-9">@Model.PaymentID</dd>
    <dt class="col-sm-3">Booking ID</dt>
    <dd class="col-sm-9">@Model.BookingID</dd>
    <dt class="col-sm-3">Amount</dt>
    <dd class="col-sm-9">@Model.Amount</dd>
    <dt class="col-sm-3">Method</dt>
    <dd class="col-sm-9">@Model.Method</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
    <dt class="col-sm-3">Date</dt>
    <dd class="col-sm-9">@Model.PaymentDate.ToShortDateString()</dd>
</dl>
<a asp-action="Index" class="btn btn-secondary">Back</a>