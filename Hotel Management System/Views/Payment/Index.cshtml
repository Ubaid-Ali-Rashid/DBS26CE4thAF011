@model IEnumerable<HotelManagementSystem.Models.Domain.Payment>
@{
    ViewData["Title"] = "Payments";
}

<h2>Payments</h2>
<a asp-action="Create" class="btn btn-primary mb-3">Add Payment</a>
<table class="table table-bordered table-striped">
    <thead>
        <tr><th>Payment ID</th><th>Booking ID</th><th>Amount</th><th>Method</th><th>Status</th><th>Date</th><th>Actions</th></tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.PaymentID</td>
                <td>@p.BookingID</td>
                <td>@p.Amount</td>
                <td>@p.Method</td>
                <td>@p.Status</td>
                <td>@p.PaymentDate.ToShortDateString()</td>
                <td><a asp-action="Details" asp-route-id="@p.PaymentID" class="btn btn-sm btn-info">Details</a></td>
            </tr>
        }
    </tbody>
</table>