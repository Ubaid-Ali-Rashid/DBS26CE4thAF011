@model HotelManagementSystem.Models.Domain.Invoice
@{
    ViewData["Title"] = "Generate Invoice";
}

<h2>Generate Invoice</h2>
<form asp-action="Create">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="BookingID" class="form-label"></label>
        <input asp-for="BookingID" class="form-control" />
        <span asp-validation-for="BookingID" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="TotalAmount" class="form-label"></label>
        <input asp-for="TotalAmount" class="form-control" />
        <span asp-validation-for="TotalAmount" class="text-danger"></span>
    </div>
    <div class="mb-3 form-check">
        <input asp-for="PaidStatus" class="form-check-input" />
        <label asp-for="PaidStatus" class="form-check-label"></label>
    </div>
    <button type="submit" class="btn btn-success">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>