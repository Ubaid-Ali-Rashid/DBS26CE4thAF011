@model HotelManagementSystem.Models.Domain.Room
@{
    ViewData["Title"] = "Room Details";
}

<h2>Room Details</h2>
<dl class="row">
    <dt class="col-sm-3">Room ID</dt>
    <dd class="col-sm-9">@Model.RoomID</dd>
    <dt class="col-sm-3">Room Number</dt>
    <dd class="col-sm-9">@Model.RoomNumber</dd>
    <dt class="col-sm-3">Type ID</dt>
    <dd class="col-sm-9">@Model.TypeID</dd>
    <dt class="col-sm-3">Floor</dt>
    <dd class="col-sm-9">@Model.Floor</dd>
    <dt class="col-sm-3">Price Per Night</dt>
    <dd class="col-sm-9">@Model.PricePerNight</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
</dl>
<a asp-action="Edit" asp-route-id="@Model.RoomID" class="btn btn-warning">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back</a>