@model IEnumerable<HotelManagementSystem.Models.Domain.Room>
@{
    ViewData["Title"] = "Rooms";
}

<h2>Rooms</h2>
<a asp-action="Create" class="btn btn-primary mb-3">Add New Room</a>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Room ID</th>
            <th>Room Number</th>
            <th>Floor</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var room in Model)
        {
            <tr>
                <td>@room.RoomID</td>
                <td>@room.RoomNumber</td>
                <td>@room.Floor</td>
                <td>@room.Status</td>
                <td>
                    <a asp-action="Details" asp-route-id="@room.RoomID" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@room.RoomID" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@room.RoomID" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>