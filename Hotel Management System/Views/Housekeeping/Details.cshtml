@model HotelManagementSystem.Models.Domain.Housekeeping
@{
    ViewData["Title"] = "Task Details";
}

<h2>Housekeeping Task Details</h2>
<dl class="row">
    <dt class="col-sm-3">Task ID</dt>
    <dd class="col-sm-9">@Model.TaskID</dd>
    <dt class="col-sm-3">Room ID</dt>
    <dd class="col-sm-9">@Model.RoomID</dd>
    <dt class="col-sm-3">Employee ID</dt>
    <dd class="col-sm-9">@Model.EmployeeID</dd>
    <dt class="col-sm-3">Scheduled Date</dt>
    <dd class="col-sm-9">@Model.ScheduledDate.ToShortDateString()</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
    <dt class="col-sm-3">Notes</dt>
    <dd class="col-sm-9">@Model.Notes</dd>
</dl>
<a asp-action="Index" class="btn btn-secondary">Back</a>