@model HotelManagementSystem.Models.Domain.Booking
@{
    ViewData["Title"] = "Delete Booking";
}

<h2>Delete Booking</h2>
<p>Are you sure you want to delete this booking?</p>
<dl class="row">
    <dt class="col-sm-3">Booking ID</dt>
    <dd class="col-sm-9">@Model.BookingID</dd>
    <dt class="col-sm-3">Guest ID</dt>
    <dd class="col-sm-9">@Model.GuestID</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
</dl>
<form asp-action="Delete">
    <input type="hidden" asp-for="BookingID" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>