@model HotelManagementSystem.Models.Domain.Booking
@{
    ViewData["Title"] = "Booking Details";
}

<h2>Booking Details</h2>
<dl class="row">
    <dt class="col-sm-3">Booking ID</dt>
    <dd class="col-sm-9">@Model.BookingID</dd>
    <dt class="col-sm-3">Guest ID</dt>
    <dd class="col-sm-9">@Model.GuestID</dd>
    <dt class="col-sm-3">Room ID</dt>
    <dd class="col-sm-9">@Model.RoomID</dd>
    <dt class="col-sm-3">Check In</dt>
    <dd class="col-sm-9">@Model.CheckIn.ToShortDateString()</dd>
    <dt class="col-sm-3">Check Out</dt>
    <dd class="col-sm-9">@Model.CheckOut.ToShortDateString()</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
    <dt class="col-sm-3">Total Amount</dt>
    <dd class="col-sm-9">@Model.TotalAmount</dd>
</dl>
<a asp-action="Edit" asp-route-id="@Model.BookingID" class="btn btn-warning">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back</a>